@page
@model ElderSense.Pages.AcessoNegadoModel
@{
    ViewData["Title"] = "Acesso Negado";
    Layout = null; // desliga os menus normais do site!
}

<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sem Permissão - ElderSense</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
            /* Fundo escuro a imitar um modal/popup aberto */
            body {
                background-color: rgba(0, 0, 0, 0.6);
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0;
            }
    </style>
</head>
<body>

    <div class="card shadow-lg border-0" style="max-width: 450px; border-radius: 15px;">
        <div class="card-body text-center p-5">

            <i class="bi bi-shield-lock-fill text-danger" style="font-size: 4rem;"></i>

            <h2 class="fw-bold mt-3 mb-3">Acesso Recusado</h2>

            <p class="text-muted mb-4">
                Desculpe, mas o seu perfil não tem autorização para aceder a esta área do sistema.
            </p>

            <a href="/" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold">
                <i class="bi bi-house-door-fill me-2"></i> Voltar à Página Inicial
            </a>

        </div>
    </div>

</body>
</html>