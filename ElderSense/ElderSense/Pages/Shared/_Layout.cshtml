<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ElderSense</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nav.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/forms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/cards.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ElderSense.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@latest/tabler-icons.min.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="db-body">
    @{
        var paginaAtual = ViewContext.RouteData.Values["page"]?.ToString();

        string ClasseAtiva(string pagina) => paginaAtual != null && paginaAtual.StartsWith(pagina) ? "active" : "";

        var utilizadorAtual = await UserManager.GetUserAsync(User);
        var nomeUtilizador = utilizadorAtual?.Nome ?? "Utilizador";
        var partesNome = nomeUtilizador.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var iniciaisUtilizador = partesNome.Length >= 2
            ? $"{partesNome[0][0]}{partesNome[^1][0]}".ToUpper()
            : nomeUtilizador.Length > 0 ? nomeUtilizador[0].ToString().ToUpper() : "?";
    }

    <div class="db-wrap">

        <aside class="db-sidebar">
            <a asp-area="" asp-page="/Index" class="db-logo">Elder<span>Sense</span></a>

            <a asp-area="" asp-page="/Index" class="db-nav-item @(paginaAtual == "/Index" ? "active" : "")">
                <i class="ti ti-home"></i> Home
            </a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                @if (User.IsInRole("Cuidador"))
                {
                    <a asp-area="" asp-page="/Sensores/Index" class="db-nav-item @ClasseAtiva("/Sensores")">
                        <i class="ti ti-wifi"></i> Sensores
                    </a>
                    <a asp-area="" asp-page="/Utilizadores/Index" class="db-nav-item @ClasseAtiva("/Utilizadores")">
                        <i class="ti ti-users"></i> Idosos
                    </a>
                    <a asp-area="" asp-page="/Alertas/Index" class="db-nav-item @ClasseAtiva("/Alertas")">
                        <i class="ti ti-bell"></i> Alertas
                    </a>
                    <a asp-area="" asp-page="/DadosMonitorizacao/Index" class="db-nav-item @ClasseAtiva("/DadosMonitorizacao")">
                        <i class="ti ti-chart-bar"></i> Dados
                    </a>
                }
                else if (User.IsInRole("Idoso"))
                {
                    <a asp-area="" asp-page="/Alertas/Index" class="db-nav-item @ClasseAtiva("/Alertas")">
                        <i class="ti ti-bell"></i> Os meus Alertas
                    </a>
                    <a asp-area="" asp-page="/DadosMonitorizacao/Index" class="db-nav-item @ClasseAtiva("/DadosMonitorizacao")">
                        <i class="ti ti-chart-bar"></i> Os meus Dados
                    </a>
                }
            }

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="db-sidebar-footer">
                    <div class="db-user">
                        <div class="db-avatar">@iniciaisUtilizador</div>
                        <div class="db-user-info">
                            <p>@nomeUtilizador</p>
                            <span>@(User.IsInRole("Cuidador") ? "Cuidador" : User.IsInRole("Idoso") ? "Idoso" : "")</span>
                        </div>
                    </div>
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })" method="post" style="width:100%;">
                        <button type="submit" class="db-nav-item db-logout-btn">
                            <i class="ti ti-logout"></i> Sair
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="db-sidebar-footer">
                    <a asp-area="Identity" asp-page="/Account/Register" class="db-nav-item">
                        <i class="ti ti-user-plus"></i> Registar
                    </a>
                    <a asp-area="Identity" asp-page="/Account/Login" class="db-nav-item">
                        <i class="ti ti-login"></i> Entrar
                    </a>
                </div>
            }
        </aside>

        <main class="db-main">
            @RenderBody()

            <footer class="db-footer">
                &copy; 2026 - ElderSense - <a asp-area="" asp-page="/Privacy">Privacy</a>
            </footer>
        </main>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>