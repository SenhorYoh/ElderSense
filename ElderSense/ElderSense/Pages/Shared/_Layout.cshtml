<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ElderSense</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nav.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/forms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/cards.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ElderSense.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@latest/tabler-icons.min.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var paginaAtual = ViewContext.RouteData.Values["page"]?.ToString();

        string ClasseAtiva(string pagina) => paginaAtual != null && paginaAtual.StartsWith(pagina) ? "active" : "";
    }

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">Elder<span>Sense</span></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link @(paginaAtual == "/Index" ? "active" : "")" asp-area="" asp-page="/Index">Home</a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Cuidador"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @ClasseAtiva("/Sensores")" asp-area="" asp-page="/Sensores/Index">Sensores</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @ClasseAtiva("/Utilizadores")" asp-area="" asp-page="/Utilizadores/Index">Utilizadores</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @ClasseAtiva("/Alertas")" asp-area="" asp-page="/Alertas/Index">Alertas</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @ClasseAtiva("/DadosMonitorizacao")" asp-area="" asp-page="/DadosMonitorizacao/Index">Dados</a>
                                </li>
                            }
                            else if (User.IsInRole("Idoso"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @ClasseAtiva("/Alertas")" asp-area="" asp-page="/Alertas/Index">Os meus Alertas</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @ClasseAtiva("/DadosMonitorizacao")" asp-area="" asp-page="/DadosMonitorizacao/Index">Os meus Dados</a>
                                </li>
                            }
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - ElderSense - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>