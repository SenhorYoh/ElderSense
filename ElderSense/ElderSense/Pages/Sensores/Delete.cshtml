@page "{id:int}"
@model ElderSense.Pages.Sensores.DeleteModel

@{
    ViewData["Title"] = "Apagar Sensor";
}

<h1>Apagar Sensor</h1>

<p class="text-danger">Tens a certeza que queres apagar este sensor?</p>

<dl class="row">
    <dt class="col-sm-2">Localização</dt>
    <dd class="col-sm-10">@Model.Sensor.Localizacao</dd>

    <dt class="col-sm-2">Tipo</dt>
    <dd class="col-sm-10">@Model.Sensor.Tipo</dd>

    <dt class="col-sm-2">Estado</dt>
    <dd class="col-sm-10">@(Model.Sensor.Estado ? "Ativo" : "Inativo")</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Sensor.Id" />
    <button type="submit" class="btn btn-danger">Apagar</button>
    <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
</form>