@page
@model ElderSense.Pages.Sensores.CreateModel

@{
    ViewData["Title"] = "Adicionar Sensor";
}

<h1>Adicionar Sensor</h1>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-floating mb-3">
        <select id="tipoSensor" asp-for="Sensor.Tipo" class="form-control"
                asp-items="Html.GetEnumSelectList<ElderSense.Data.Model.TipoSensor>()">
            <option value="">Selecione o tipo...</option>
        </select>
        <label asp-for="Sensor.Tipo">Tipo de Sensor</label>
        <span asp-validation-for="Sensor.Tipo" class="text-danger"></span>
    </div>

    <div id="grupoLocalizacao">
        <div class="form-floating mb-3">
            <select id="localizacaoPredefinida" class="form-control">
                <option value="">Selecione a localização...</option>
                <option value="Cozinha">Cozinha</option>
                <option value="Sala">Sala</option>
                <option value="Quarto">Quarto</option>
                <option value="Casa de Banho">Casa de Banho</option>
                <option value="Entrada">Entrada</option>
                <option value="Garagem">Garagem</option>
                <option value="Outro">Outro (escrever)</option>
            </select>
            <label for="localizacaoPredefinida">Localização</label>
        </div>

        <div class="form-floating mb-3" id="grupoLocalizacaoTexto" style="display: none;">
            <input asp-for="Sensor.Localizacao" class="form-control" placeholder="Ex: Quarto 2" />
            <label asp-for="Sensor.Localizacao">Especificar Localização</label>
            <span asp-validation-for="Sensor.Localizacao" class="text-danger"></span>
        </div>
    </div>

    <div class="form-check mb-3">
        <input asp-for="Sensor.Estado" class="form-check-input" />
        <label asp-for="Sensor.Estado" class="form-check-label">Ativo</label>
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const tipoSensor = document.getElementById("tipoSensor");
        const grupoLocalizacao = document.getElementById("grupoLocalizacao");
        const localizacaoPredefinida = document.getElementById("localizacaoPredefinida");
        const grupoLocalizacaoTexto = document.getElementById("grupoLocalizacaoTexto");
        const inputLocalizacao = document.querySelector("[name='Sensor.Localizacao']");

        // mostra ou esconde o campo de localização com base no tipo de sensor escolhido
        function atualizarVisibilidadeLocalizacao() {
            if (tipoSensor.value === "Pulseira") {
                grupoLocalizacao.style.display = "none";
                inputLocalizacao.value = "Corpo do idoso"; // valor fixo, sem sentido editar
            } else {
                grupoLocalizacao.style.display = "block";
                if (inputLocalizacao.value === "Corpo do idoso") {
                    inputLocalizacao.value = "";
                }
            }
        }

        // quando o utilizador escolhe uma localização predefinida, copia para o campo real
        localizacaoPredefinida.addEventListener("change", function () {
            if (this.value === "Outro") {
                grupoLocalizacaoTexto.style.display = "block";
                inputLocalizacao.value = "";
            } else {
                grupoLocalizacaoTexto.style.display = "none";
                inputLocalizacao.value = this.value;
            }
        });

        tipoSensor.addEventListener("change", atualizarVisibilidadeLocalizacao);

        // estado inicial ao carregar a página
        atualizarVisibilidadeLocalizacao();
    </script>
}