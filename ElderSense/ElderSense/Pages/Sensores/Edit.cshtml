@page "{id:int}"
@model ElderSense.Pages.Sensores.EditModel

@{
    ViewData["Title"] = "Editar Sensor";
}

<h1>Editar Sensor</h1>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input type="hidden" asp-for="Sensor.Id" />
    <input type="hidden" asp-for="Sensor.FKUtilizador" />

    <div class="form-floating mb-3">
        <input asp-for="Sensor.Localizacao" class="form-control" placeholder="Ex: Sala" />
        <label asp-for="Sensor.Localizacao">Localização</label>
        <span asp-validation-for="Sensor.Localizacao" class="text-danger"></span>
    </div>

    <div class="form-floating mb-3">
        <select asp-for="Sensor.Tipo" class="form-control"
                asp-items="Html.GetEnumSelectList<ElderSense.Data.Model.TipoSensor>()">
        </select>
        <label asp-for="Sensor.Tipo">Tipo de Sensor</label>
        <span asp-validation-for="Sensor.Tipo" class="text-danger"></span>
    </div>

    <div id="grupoIdoso" class="form-floating mb-3">
        <select id="selectIdoso" asp-for="Sensor.FKIdoso" class="form-control" asp-items="Model.ListaIdosos">
            <option value="">-- Nenhum idoso associado --</option>
        </select>
        <label asp-for="Sensor.FKIdoso">Idoso monitorizado</label>
        <span asp-validation-for="Sensor.FKIdoso" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        @if (Model.Sensor.Arquivado)
        {
            <div class="alert alert-secondary">
                Este sensor está <strong>arquivado</strong>. Reative-o na lista de sensores antes de o poder ativar.
            </div>
            <input type="hidden" asp-for="Sensor.Estado" value="false" />
        }
        else
        {
            <div class="form-check mb-3">
                <input asp-for="Sensor.Estado" class="form-check-input" />
                <label asp-for="Sensor.Estado" class="form-check-label">Ativo</label>
            </div>
        }
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const tipoSensor = document.querySelector("[name='Sensor.Tipo']");
        const grupoIdoso = document.getElementById("grupoIdoso");
        const selectIdoso = document.getElementById("selectIdoso");

        // O enum TipoSensor gera value="0" para Beacon e value="1" para Pulseira
        const VALOR_PULSEIRA = "1";

        // mostra o dropdown do idoso apenas quando o sensor é uma Pulseira.
        // O Beacon não tem idoso fixo (sorteia da lista do cuidador a cada leitura)
        function atualizarVisibilidadeIdoso() {
            if (tipoSensor.value === VALOR_PULSEIRA) {
                grupoIdoso.style.display = "block";
            } else {
                grupoIdoso.style.display = "none";
                selectIdoso.value = ""; // limpa a associação se mudar para Beacon
            }
        }

        tipoSensor.addEventListener("change", atualizarVisibilidadeIdoso);

        // estado inicial ao carregar a página
        atualizarVisibilidadeIdoso();
    </script>
}