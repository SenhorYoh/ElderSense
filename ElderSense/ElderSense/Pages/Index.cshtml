@page
@model IndexModel
@{
    /* Define o título e o layout exclusivo da landing page */
    ViewData["Title"] = "ElderSense";
    Layout = "_LayoutLanding";
}

<!--Nota: O "es" das classes significa ElderSense-->

<!-- Texto oculto para leitores de ecrã (acessibilidade) -->
<h2 class="sr-only">Landing page ElderSense</h2>

<!-- ==================== NAVEGAÇÃO ==================== -->
<nav class="es-nav">
    <div class="es-logo">Elder<span>Sense</span></div>
    <div class="es-nav-links">
        <a href="#como-funciona">Como funciona</a>
        <a href="#planos">Planos</a>
        <a href="#contacto">Contacto</a>
        <!-- Se estiver autenticado mostra link para o dashboard, senão mostra entrar -->
        @if (User.Identity!.IsAuthenticated)
        {
            <a asp-page="/Dashboard" class="es-btn-nav">Dashboard</a>
        }
        else
        {
            <a asp-page="/Account/Login" asp-area="Identity" class="es-btn-nav">Entrar</a>
        }
    </div>
</nav>

<!-- ==================== HERO ==================== -->
<div class="es-hero">

    <!-- Selo de confiança no topo -->
    <div class="es-badge">
        <i class="ti ti-shield-check"></i> Sem câmaras. Sem microfones.
    </div>

    <!-- Título principal -->
    <h1>Tranquilidade para a família,<br><em>autonomia para o idoso.</em></h1>

    <!-- Descrição curta do produto -->
    <p>O ElderSense monitoriza a rotina do seu familiar em casa, detetando desvios e enviando alertas apenas quando é necessário — sem vigilância invasiva.</p>

    <!-- Botões de ação principais -->
    <div class="es-hero-btns">
        <a href="#planos" class="es-btn-primary">Ver planos <i class="ti ti-arrow-right"></i></a>
        <a href="#como-funciona" class="es-btn-outline">Como funciona</a>
    </div>
</div>

<hr class="es-divider">

<!-- ==================== PROPOSTA DE VALOR ==================== -->
<section class="es-section" id="proposta">

    <!-- Etiqueta da secção -->
    <div class="es-section-label">Proposta de valor</div>

    <h2>Tecnologia que cuida sem invadir</h2>
    <p>Em vez de câmaras ou interações constantes, o ElderSense interpreta padrões de comportamento e emite alertas apenas quando existe um desvio relevante face à rotina esperada.</p>

    <!-- Três cards com os benefícios principais -->
    <div class="es-cards">

        <!-- Card do cuidador -->
        <div class="es-card">
            <div class="es-card-icon"><i class="ti ti-heart"></i></div>
            <h3>Para o cuidador</h3>
            <p>Reduz ansiedade e centraliza a informação. Sabe quando deve intervir.</p>
        </div>

        <!-- Card do idoso -->
        <div class="es-card">
            <div class="es-card-icon"><i class="ti ti-user"></i></div>
            <h3>Para o idoso</h3>
            <p>Preserva a autonomia, privacidade e dignidade no dia a dia.</p>
        </div>

        <!-- Card dos alertas -->
        <div class="es-card">
            <div class="es-card-icon"><i class="ti ti-bell"></i></div>
            <h3>Alertas inteligentes</h3>
            <p>Notificações contextualizadas, sem ruído desnecessário ou falsos alarmes.</p>
        </div>
    </div>
</section>

<hr class="es-divider">

<!-- ==================== COMO FUNCIONA ==================== -->
<section class="es-section" id="como-funciona">

    <!-- Etiqueta da secção -->
    <div class="es-section-label">Como funciona</div>

    <h2>Simples para si. Invisível para o idoso.</h2>

    <!-- Passos numerados do processo -->
    <div class="es-how">

        <!-- Passo 1 -->
        <div class="es-step">
            <div class="es-step-num">1</div>
            <div class="es-step-content">
                <h4>Escolhe um plano e recebe os sensores</h4>
                <p>Sensores discretos instalados em casa captam movimentos e padrões de rotina sem câmaras ou microfones.</p>
            </div>
        </div>

        <!-- Passo 2 -->
        <div class="es-step">
            <div class="es-step-num">2</div>
            <div class="es-step-content">
                <h4>Configura a rotina habitual</h4>
                <p>Define horários de refeições, medicação e atividades. O sistema aprende o que é normal para o seu familiar.</p>
            </div>
        </div>

        <!-- Passo 3 -->
        <div class="es-step">
            <div class="es-step-num">3</div>
            <div class="es-step-content">
                <h4>Recebe alertas apenas quando importa</h4>
                <p>Quando algo foge ao padrão habitual, recebe uma notificação com contexto — sem alarmes constantes.</p>
            </div>
        </div>

        <!-- Passo 4 -->
        <div class="es-step">
            <div class="es-step-num">4</div>
            <div class="es-step-content">
                <h4>Acompanha tudo na plataforma web e app</h4>
                <p>Dashboard com rotina diária, histórico de alertas e estado dos sensores, acessível em qualquer dispositivo.</p>
            </div>
        </div>
    </div>
</section>

<hr class="es-divider">

<!-- ==================== PLANOS ==================== -->
<section class="es-section" id="planos">

    <!-- Etiqueta da secção -->
    <div class="es-section-label">Planos</div>

    <h2>Escolha o plano certo para a sua família</h2>
    <p>Todos os planos incluem acesso à plataforma web, app móvel e suporte técnico. Sem contratos de longo prazo.</p>

    <!-- Grelha com os três planos disponíveis -->
    <div class="es-pricing">

        <!-- Plano básico -->
        <div class="es-plan">
            <h3>Básico</h3>
            <div class="es-plan-price">€14,99 <span>/ mês</span></div>
            <p class="es-plan-desc">Para famílias que querem um primeiro nível de acompanhamento.</p>
            <ul class="es-plan-features">
                <li><i class="ti ti-check"></i> 2 sensores incluídos</li>
                <li><i class="ti ti-check"></i> Alertas por email</li>
                <li><i class="ti ti-check"></i> Dashboard básico</li>
                <li><i class="ti ti-check"></i> 1 cuidador</li>
            </ul>
            <a href="#" class="es-btn-outline" style="width:100%; text-align:center; margin-top:auto;">Começar</a>
        </div>

        <!-- Plano familiar — destaque como mais popular -->
        <div class="es-plan featured">
            <div class="es-plan-badge">Mais popular</div>
            <h3>Familiar</h3>
            <div class="es-plan-price">€24,99 <span>/ mês</span></div>
            <p class="es-plan-desc">Para famílias que querem acompanhamento completo e tranquilidade total.</p>
            <ul class="es-plan-features">
                <li><i class="ti ti-check"></i> 5 sensores incluídos</li>
                <li><i class="ti ti-check"></i> Alertas push + email</li>
                <li><i class="ti ti-check"></i> Dashboard completo</li>
                <li><i class="ti ti-check"></i> Até 3 cuidadores</li>
                <li><i class="ti ti-check"></i> Insights de rotina</li>
            </ul>
            <a href="#" class="es-btn-primary" style="width:100%; text-align:center; margin-top:auto;">Escolher plano</a>
        </div>

        <!-- Plano institucional — para organizações -->
        <div class="es-plan">
            <h3>Institucional</h3>
            <div class="es-plan-price">Sob consulta</div>
            <p class="es-plan-desc">Para IPSS, lares e serviços de apoio domiciliário com múltiplos utentes.</p>
            <ul class="es-plan-features">
                <li><i class="ti ti-check"></i> Sensores ilimitados</li>
                <li><i class="ti ti-check"></i> Painel de gestão</li>
                <li><i class="ti ti-check"></i> Relatórios avançados</li>
                <li><i class="ti ti-check"></i> Suporte dedicado</li>
            </ul>
            <a href="#contacto" class="es-btn-outline" style="width:100%; text-align:center; margin-top:auto;">Falar connosco</a>
        </div>
    </div>
</section>

<hr class="es-divider">

<!-- ==================== CONFIANÇA / CONTACTO ==================== -->
<section class="es-section" id="contacto">

    <!-- Três pilares de confiança do produto -->
    <div class="es-trust">

        <!-- Pilar 1 - Privacidade -->
        <div class="es-trust-item">
            <i class="ti ti-lock"></i>
            <p>Sem câmaras nem microfones. Privacidade garantida.</p>
        </div>

        <!-- Pilar 2 - Hardware -->
        <div class="es-trust-item">
            <i class="ti ti-wifi"></i>
            <p>Sensores IoT discretos e fáceis de instalar.</p>
        </div>

        <!-- Pilar 3 - Plataforma -->
        <div class="es-trust-item">
            <i class="ti ti-device-mobile"></i>
            <p>App móvel e plataforma web incluídas.</p>
        </div>
    </div>
</section>