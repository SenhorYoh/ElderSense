@page
@model ElderSense.Pages.Utilizadores.IndexModel

@{
    ViewData["Title"] = "Utilizadores";
}

<div class="db-header">
    <h1>Utilizadores</h1>
    <p>Cuidadores e idosos registados na plataforma</p>
</div>

<div class="db-stats">
    <div class="db-stats-item">
        <div class="db-stats-label">Total</div>
        <div class="db-stats-value">@Model.TotalUtilizadores</div>
    </div>
    <div class="db-stats-divider"></div>
    <div class="db-stats-item">
        <div class="db-stats-label">Cuidadores</div>
        <div class="db-stats-value success">@Model.TotalCuidadores</div>
    </div>
    <div class="db-stats-divider"></div>
    <div class="db-stats-item">
        <div class="db-stats-label">Idosos</div>
        <div class="db-stats-value">@Model.TotalIdosos</div>
    </div>
</div>

<p>
    <a asp-page="Create" class="btn-acao btn-acao-adicionar">
        <i class="ti ti-plus"></i> Adicionar Utilizador
    </a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Email</th>
            <th>Tipo</th>
            <th>Telefone</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var utilizador in Model.Utilizadores)
        {
            <tr>
                <td>@utilizador.Nome</td>
                <td>@utilizador.Email</td>
                <td>@utilizador.Tipo</td>
                <td>@utilizador.Telefone</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@utilizador.Id" class="btn-acao btn-acao-editar">
                        <i class="ti ti-edit"></i> Editar
                    </a>
                    <a asp-page="Delete" asp-route-id="@utilizador.Id" class="btn-acao btn-acao-apagar">
                        <i class="ti ti-trash"></i> Apagar
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>