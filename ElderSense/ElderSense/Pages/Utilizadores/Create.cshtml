@page
@model ElderSense.Pages.Utilizadores.CreateModel

@{
    ViewData["Title"] = "Adicionar Utilizador";
}

<h1>Adicionar Utilizador</h1>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-floating mb-3">
        <input asp-for="Utilizador.Nome" class="form-control" placeholder="Nome" />
        <label asp-for="Utilizador.Nome">Nome</label>
        <span asp-validation-for="Utilizador.Nome" class="text-danger"></span>
    </div>

    <div class="form-floating mb-3">
        <input asp-for="Utilizador.Email" class="form-control" placeholder="Email" />
        <label asp-for="Utilizador.Email">Email</label>
        <span asp-validation-for="Utilizador.Email" class="text-danger"></span>
    </div>

    <div class="form-floating mb-3">
        <input asp-for="Utilizador.DataNascimento" class="form-control" type="date" min="1900-01-01" max="@DateTime.Now.ToString("yyyy-MM-dd")" />
        <label asp-for="Utilizador.DataNascimento">Data de Nascimento</label>
        <span asp-validation-for="Utilizador.DataNascimento" class="text-danger"></span>
    </div>

    <div class="form-floating mb-3">
        <select asp-for="Utilizador.Tipo" class="form-control"
                asp-items="Html.GetEnumSelectList<ElderSense.Data.Model.TipoUtilizador>()">
            <option value="">Selecione o tipo...</option>
        </select>
        <label asp-for="Utilizador.Tipo">Tipo</label>
        <span asp-validation-for="Utilizador.Tipo" class="text-danger"></span>
    </div>

    <div class="form-floating mb-3">
        <input asp-for="Utilizador.Telefone" class="form-control" placeholder="Telefone" />
        <label asp-for="Utilizador.Telefone">Telefone</label>
    </div>

    <div class="form-floating mb-3">
        <input asp-for="Password" class="form-control" type="password" placeholder="Password" />
        <label asp-for="Password">Password</label>
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}