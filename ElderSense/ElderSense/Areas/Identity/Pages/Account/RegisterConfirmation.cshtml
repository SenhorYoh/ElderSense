@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Confirmação de registo";
}

<h1>@ViewData["Title"]</h1>
@{
    if (@Model.DisplayConfirmAccountLink)
    {
        <p>
            Esta aplicação não tem atualmente um serviço de envio de email real configurado, consulte <a href="https://aka.ms/aspaccountconf">esta documentação</a> para saber como configurar um serviço de email real.
            Normalmente isto seria enviado por email: <a id="confirm-link" href="@Model.EmailConfirmationUrl">Clique aqui para confirmar a sua conta</a>
        </p>
    }
    else
    {
        <p>
            Por favor verifique o seu email para confirmar a sua conta.
        </p>
    }
}