@page
@model LoginModel
@{
    /* Usa o layout da landing page para consistência visual */
    Layout = "_LayoutLanding";
    ViewData["Title"] = "Entrar";
}

<!-- ==================== PÁGINA DE LOGIN ==================== -->
<div class="login-page">

    <!-- Navbar simples consistente com a landing page -->
    <nav class="es-nav">
        <a asp-page="/Index" class="es-logo">Elder<span>Sense</span></a>
        <div class="es-nav-links">
            <a asp-page="/Index">Voltar ao início</a>
        </div>
    </nav>

    <!-- Contentor central do formulário -->
    <div class="login-wrap">

        <!-- Cabeçalho -->
        <div class="login-header">
            <div class="es-logo" style="font-size:22px; margin-bottom:1rem;">Elder<span>Sense</span></div>
            <h1>Bem-vindo de volta</h1>
            <p>Introduz o teu email para entrares ou criares conta.</p>
        </div>

        <!-- Formulário principal -->
        <section>
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="login-error" role="alert"></div>

                @if (!Model.ShowPassword)
                {
                    <!-- Passo 1 — campo de email -->
                    <div class="login-field">
                        <label asp-for="Input.Email">Email</label>
                        <input asp-for="Input.Email" class="login-input" placeholder="name@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                }
                else
                {
                    <!-- Campo hidden para manter o email entre os dois passos -->
                    <input type="hidden" asp-for="Input.Email" />

                    <!-- Passo 2 — campo de password -->
                    <div class="login-field">
                        <label asp-for="Input.Password">Password</label>
                        <input asp-for="Input.Password" class="login-input" placeholder="A tua password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                }

                <!-- Botão principal -->
                <button id="login-submit" type="submit" class="es-btn-primary" style="width:100%; justify-content:center;">
                    Seguinte <i class="ti ti-arrow-right"></i>
                </button>

                <!-- Link para recuperar password -->
                <div class="login-links">
                    <a asp-page="./ForgotPassword">Esqueceu-se da password?</a>
                </div>
            </form>
        </section>

        <!-- Divisor -->
        <div class="login-divider">
            <span>ou continuar com</span>
        </div>

        <!-- Login com Google -->
        <section>
            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" style="text-align:center;">
                @foreach (var provider in Model.ExternalLogins!)
                {
                    <button type="submit" class="btn-google-icon" name="provider" value="@provider.Name">
                        <img src="~/images/google-logo.png" alt="Google" style="width:24px;" />
                    </button>
                }
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
