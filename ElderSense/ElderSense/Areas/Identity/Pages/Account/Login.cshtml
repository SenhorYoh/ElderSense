@page
@model LoginModel


<h1>@ViewData["Title"]</h1>
<div class="login-container-vertical">
    <section>
        <form id="account" method="post">
            <h2 class="text-center">Introduz o teu email para te juntares a nós</h2>
            <h2 class="text-center">Ou para iniciar sessão</h2>
            <hr />
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            @if (!Model.ShowPassword)
            {
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
            }
            else
            {
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" placeholder="password" />
                    <label asp-for="Input.Password">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
            }

            <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Seguinte</button>
            
            <div class="mt-3 text-center">
                <a id="forgot-password" asp-page="./ForgotPassword">Esqueceu-se da password?</a>
            </div>
        </form>
    </section>

    <!-- Secção do Google logo abaixo -->
    <section class="external-login-wrapper">
        <p>Ou entrar com:</p>
        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            @foreach (var provider in Model.ExternalLogins!)
            {
                <button type="submit" class="btn-google-icon" name="provider" value="@provider.Name">
                    <img src="~/images/google-logo.png" alt="Google" style="width:24px;" />
                </button>
            }
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
