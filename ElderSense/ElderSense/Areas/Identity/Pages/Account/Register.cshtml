@page
@model RegisterModel

@{
    Layout = "_LayoutLanding";
}

<nav class="es-nav">
    <a asp-page="/Index" class="es-logo">Elder<span>Sense</span></a>
    <div class="es-nav-links">
        <a asp-page="/Kits" class="es-nav-featured">Kits</a>
        <a href="/#como-funciona">Como funciona</a>
        <a href="/#planos">Planos</a>
        <a href="/#contacto">Contacto</a>
        <a asp-page="/Account/Login" asp-area="Identity" class="es-btn-nav">Entrar</a>
    </div>
</nav>

<div class="login-container-vertical">
    <section>
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <h2 class="text-center">Criar conta</h2>
            <hr />
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <!-- Nome -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Nome" class="form-control" aria-required="true" placeholder="O seu nome" />
                <label asp-for="Input.Nome">Nome Completo</label>
                <span asp-validation-for="Input.Nome" class="text-danger"></span>
            </div>

            <!-- Data de Nascimento -->
            <div class="form-floating mb-3">
                <input asp-for="Input.DataNascimento" class="form-control" type="date" />
                <label asp-for="Input.DataNascimento">Data de Nascimento</label>
                <span asp-validation-for="Input.DataNascimento" class="text-danger"></span>
            </div>

            <!-- Email (Pode vir preenchido do Login) -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="nome@exemplo.com" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <!-- Password -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Password" />
                <label asp-for="Input.Password">Password</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <!-- Confirmar Password -->
            <div class="form-floating mb-3">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Password" />
                <label asp-for="Input.ConfirmPassword">Confirmar Password</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">Registar</button>
        </form>
    </section>

    <!-- Secção de Login Externo-->
    <section class="external-login-wrapper">
        <hr />
        <h5 class="text-center mb-3">Ou registar com:</h5>
        @{
            if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="text-center">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" class="btn-google-icon" name="provider" value="@provider.Name" title="Registar com @provider.DisplayName">
                            @if (provider.DisplayName == "Google")
                            {
                                <img src="~/images/google-logo.png" alt="Google" style="width:24px;" />
                            }
                            else
                            {
                                @provider.DisplayName
                            }
                        </button>
                    }
                </form>
            }
        }
    </section>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}